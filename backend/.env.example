# ==============================================
# Backend Environment Variables
# ==============================================

# Port server backend dijalankan (default: 4000)
PORT=4000

# Lingkungan aplikasi (development / production)
NODE_ENV=development

# URL Koneksi Database MySQL (Aiven MySQL / Local MySQL)
# Format: mysql://user:password@host:port/database_name?ssl-mode=REQUIRED
DATABASE_URL="mysql://avnadmin:password@host:port/defaultdb?ssl-mode=REQUIRED"

# Kunci Rahasia JWT (Gunakan string acak yang panjang di production)
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_EXPIRES_IN="7d"

# URL Frontend untuk izin CORS (Bisa koma-terpisah di production)
# Contoh: https://www.domain.com,https://domain.com
FRONTEND_URL="http://localhost:3000"
